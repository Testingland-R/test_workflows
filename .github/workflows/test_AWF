name: CI
on:
  workflow_dispatch:
    inputs:
      base_branch:
        description: 'Base branch for PR (target)'
        required: true
        default: 'master'
        type: string
      head_branch:
        description: 'Head branch for PR (source)'
        required: true
        default: 'development'
        type: string

jobs:
  call-reusable-workflow:
    uses: roquevaamonde/workflows/.github/workflows/python_CI.yml@main
    with:
      python-version: '3.11'
