{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:base",
    ":dependencyDashboard"
  ],
  "pinDigests": true,
  "platformAutomerge": true,
  "dependencyDashboard": true,
  "automerge": true,
  "automergeType": "pr",
  "automergeStrategy": "squash",
  "packageRules": [
    {
      "matchManagers": ["github-actions"],
      "matchFileNames": [".github/workflows/pytest-scan.yml"],
      "groupName": "pytest-scan-deps"
    },
    {
      "matchManagers": ["github-actions"],
      "matchFileNames": [".github/workflows/sonarqube-scan.yml"],
      "groupName": "sonarqube-scan-deps"
    },
        {
      "matchManagers": ["github-actions"],
      "matchFileNames": [".github/workflows/Renovate_auto_aprove.yml"],
      "groupName": "Renovate_auto_aprove.yml"
    },
    {
      "matchPackagePatterns": ["*"],
      "matchUpdateTypes": ["digest"],
      "automerge": true
    }
  ]
}
